{
    "name": "Arena Brain v3 -- Developmental (harsh pruning, 50% target survival)",
    "description": "V3 of blank slate. Goal: prune ~50% of developmental synapses (matching human biology). Pruning threshold 30% coincidence rate. This WILL break things. The question is whether the surviving topology is useful.",
    "output": "brains/zoo/arena_dev_v3.db",
    "seed": 42,
    "layer_spacing": 50.0,

    "components": [
        {"type": "sensory_bank", "count": 100, "layer": 0},
        {"type": "state_machine_3", "count": 30, "layer": 0},
        {"type": "winner_take_all", "count": 50, "layer": 0},

        {"type": "mechanosensory", "count": 80, "layer": 1},
        {"type": "binary_decision", "count": 40, "layer": 1},
        {"type": "forward_motor", "count": 40, "layer": 1},
        {"type": "backward_motor", "count": 30, "layer": 1},
        {"type": "cross_inhibition", "count": 30, "layer": 1},
        {"type": "head_steering", "count": 30, "layer": 1},

        {"type": "working_memory_cell", "count": 200, "layer": 2},
        {"type": "sequence_detector", "count": 60, "layer": 2},

        {"type": "emotional_state", "count": 100, "layer": 3},
        {"type": "novelty_detector", "count": 120, "layer": 3},
        {"type": "lateral_inhibition", "count": 30, "layer": 3},
        {"type": "gain_controller", "count": 60, "layer": 3},
        {"type": "bistable_motif", "count": 40, "layer": 3},

        {"type": "rebound_timer", "count": 100, "layer": 4},
        {"type": "activity_brake", "count": 60, "layer": 4},
        {"type": "cpg_oscillator", "count": 20, "layer": 4},
        {"type": "burst_rebound", "count": 12, "layer": 4},
        {"type": "modulatory", "count": 20, "layer": 4}
    ],

    "projections": [
        {"_comment": "=== FIXED SPINE ==="},
        {"from_type": "mechanosensory", "to_type": "binary_decision",
         "from_terminal": "reverse_out", "to_terminal": "sensory_b_in",
         "weight": 9.0, "probability": 0.65, "synapse_type": "fixed"},
        {"from_type": "mechanosensory", "to_type": "binary_decision",
         "from_terminal": "forward_out", "to_terminal": "sensory_a_in",
         "weight": 8.0, "probability": 0.65, "synapse_type": "fixed"},
        {"from_type": "binary_decision", "to_type": "forward_motor",
         "from_terminal": "option_a_out", "to_terminal": "command_in",
         "weight": 10.0, "probability": 0.5, "synapse_type": "fixed"},
        {"from_type": "binary_decision", "to_type": "backward_motor",
         "from_terminal": "option_b_out", "to_terminal": "command_in",
         "weight": 12.0, "probability": 0.5, "synapse_type": "fixed"},

        {"_comment": "=== DEVELOPMENTAL: harsh pruning (30% threshold) ==="},

        {"from_type": "sensory_bank", "from_terminal": "sensory_out",
         "to_type": "working_memory_cell", "to_terminal": "trigger_in",
         "weight": 3.0, "probability": 0.25, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"from_type": "sensory_bank", "from_terminal": "sensory_out",
         "to_type": "novelty_detector",
         "weight": 5.0, "probability": 0.3, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"from_type": "mechanosensory", "to_type": "novelty_detector",
         "weight": 5.0, "probability": 0.4, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"from_type": "novelty_detector", "to_type": "emotional_state",
         "from_terminal": "novelty_out", "to_terminal": "trigger_in",
         "weight": 6.0, "probability": 0.4, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"from_type": "working_memory_cell", "to_type": "emotional_state",
         "from_terminal": "memory_out", "to_terminal": "trigger_in",
         "weight": 3.0, "probability": 0.15, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"from_type": "working_memory_cell", "to_type": "working_memory_cell",
         "from_terminal": "memory_out", "to_terminal": "association_in",
         "weight": 1.5, "probability": 0.12, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.40, "min_source_fires": 10}},

        {"from_type": "mechanosensory", "to_type": "working_memory_cell",
         "weight": 3.0, "probability": 0.15, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"from_type": "state_machine_3", "to_type": "binary_decision",
         "weight": 2.0, "probability": 0.2, "synapse_type": "developmental",
         "params": {"critical_period": 50000, "eval_interval": 5000, "pruning_threshold": 0.30, "min_source_fires": 10}},

        {"_comment": "=== REWARD PLASTIC ==="},
        {"from_type": "emotional_state", "to_type": "binary_decision",
         "from_terminal": "emotion_out", "to_terminal": "modulator_a_in",
         "weight": 1.0, "probability": 0.15, "synapse_type": "reward_plastic",
         "params": {"learning_rate": 0.01, "w_min": 0.0, "w_max": 10.0,
                    "tau_trace": 20, "tau_eligible": 500}},
        {"from_type": "emotional_state", "to_type": "binary_decision",
         "from_terminal": "emotion_out", "to_terminal": "modulator_b_in",
         "weight": 1.0, "probability": 0.15, "synapse_type": "reward_plastic",
         "params": {"learning_rate": 0.01, "w_min": 0.0, "w_max": 10.0,
                    "tau_trace": 20, "tau_eligible": 500}},

        {"_comment": "=== FIXED calming loop ==="},
        {"from_type": "emotional_state", "to_type": "rebound_timer",
         "from_terminal": "emotion_out", "to_terminal": "inhibit_in",
         "weight": 7.0, "probability": 0.3, "synapse_type": "fixed"},
        {"from_type": "rebound_timer", "to_type": "emotional_state",
         "from_terminal": "rebound_out", "to_terminal": "calm_in",
         "weight": 8.0, "probability": 0.3, "synapse_type": "fixed"}
    ],

    "wiring": {
        "max_distance": 12.0,
        "probability": 0.08,
        "weight_scale": 1.0,
        "type_aware_inhibition": true,
        "protected_triggers": {
            "binary_decision": ["sensory_a_in", "sensory_b_in", "modulator_a_in", "modulator_b_in"],
            "working_memory_cell": ["trigger_in"],
            "emotional_state": ["trigger_in", "calm_in"],
            "forward_motor": ["command_in"],
            "backward_motor": ["command_in"],
            "state_machine_3": ["trigger_a", "trigger_b", "trigger_c"],
            "novelty_detector": ["stimulus_in"],
            "sequence_detector": ["sequence_a", "sequence_b"],
            "sensory_bank": ["channel_in"]
        }
    }
}
